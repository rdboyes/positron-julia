{
  "compilerOptions": {
    "module": "nodenext",
    "target": "ES2020",
    "outDir": "out",
    "moduleResolution": "nodenext",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false,
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "*": ["./node_modules/*"]
    }
  },
  "include": [
    "src/**/*",
    "typings/positron.d.ts",
    "typings/vscode.d.ts"
  ]
}
