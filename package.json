{
  "name": "positron-julia",
  "displayName": "Julia for Positron",
  "description": "Julia language support for Positron IDE",
  "version": "0.1.5",
  "publisher": "ntluong95",
  "author": "TidierOrg, rdboyes, ntluong95",
  "contributors": [
    {
      "name": "TidierOrg"
    },
    {
      "name": "rdboyes"
    },
    {
      "name": "ntluong95"
    }
  ],
  "license": "SEE LICENSE IN LICENSE",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/TidierOrg/positron-julia"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Programming Languages",
    "Data Science"
  ],
  "main": "./out/extension.js",
  "icon": "./resources/branding/julia-logo.png",
  "activationEvents": [
    "onLanguageRuntime:julia",
    "onLanguage:julia",
    "onCommand:julia.createNewFile",
    "onCommand:julia.selectInterpreter",
    "onCommand:julia.runFile",
    "onCommand:julia.runSelection",
    "onCommand:julia.toggleOutline",
    "onCommand:julia.restartLanguageServer",
    "onCommand:julia.refreshLanguageServer",
    "onCommand:julia.interrupt",
    "onCommand:julia.changeCurrentEnvironment",
    "onCommand:julia.executeCell",
    "onCommand:julia.executeCellAndMove",
    "onCommand:julia.stopTestProcess",
    "onCommand:julia.stopTestController",
    "onCommand:julia.runEditorContents",
    "onCommand:julia.debugEditorContents",
    "onDebugInitialConfigurations",
    "onDebugResolve:julia"
  ],
  "contributes": {
    "languageRuntimes": [
      {
        "languageId": "julia"
      }
    ],
    "languages": [
      {
        "id": "julia",
        "extensions": [
          ".jl"
        ],
        "aliases": [
          "Julia",
          "julia"
        ],
        "configuration": "./language-configuration/julia-language-configuration.json"
      },
      {
        "id": "julia-markdown",
        "extensions": [
          ".jmd"
        ],
        "aliases": [
          "Julia Markdown",
          "julia markdown"
        ]
      }
    ],
    "grammars": [
      {
        "language": "julia",
        "scopeName": "source.julia",
        "path": "./syntaxes/julia_vscode.json"
      },
      {
        "language": "julia-markdown",
        "scopeName": "text.html.markdown.julia",
        "path": "./syntaxes/juliamarkdown.json",
        "embeddedLanguages": {
          "meta.embedded.block.julia": "julia"
        }
      },
      {
        "scopeName": "markdown.julia.codeblock",
        "path": "./syntaxes/juliacodeblock.json",
        "injectTo": [
          "text.html.markdown",
          "text.html.markdown.julia"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.julia": "julia"
        }
      },
      {
        "scopeName": "source.docstring.julia",
        "path": "./syntaxes/juliadocstring.json",
        "injectTo": [
          "source.julia"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.julia": "julia"
        }
      }
    ],
    "commands": [
      {
        "command": "julia.createNewFile",
        "category": "Julia",
        "title": "New Julia File"
      },
      {
        "command": "julia.selectInterpreter",
        "category": "Julia",
        "title": "Select Julia Interpreter"
      },
      {
        "command": "julia.runFile",
        "category": "Julia",
        "title": "Run File",
        "icon": "$(play)"
      },
      {
        "command": "julia.runSelection",
        "category": "Julia",
        "title": "Run Selection"
      },
      {
        "command": "julia.toggleOutline",
        "category": "Julia",
        "title": "Toggle Outline",
        "when": "editorLangId == julia",
        "icon": "$(list-unordered)",
        "actionBarOptions": {
          "controlType": "button",
          "displayTitle": false
        }
      },
      {
        "command": "julia.restartLanguageServer",
        "category": "Julia",
        "title": "Restart Language Server"
      },
      {
        "command": "julia.refreshLanguageServer",
        "category": "Julia",
        "title": "Refresh Language Server"
      },
      {
        "command": "julia.interrupt",
        "category": "Julia",
        "title": "Interrupt Julia Execution",
        "icon": "$(debug-pause)"
      },
      {
        "command": "julia.changeCurrentEnvironment",
        "category": "Julia",
        "title": "Change Current Environment"
      },
      {
        "command": "julia.executeCell",
        "category": "Julia",
        "title": "Execute Code Cell"
      },
      {
        "command": "julia.executeCellAndMove",
        "category": "Julia",
        "title": "Execute Code Cell and Move to Next"
      },
      {
        "command": "julia.stopTestProcess",
        "category": "Julia",
        "title": "Stop Test Process",
        "icon": "$(debug-stop)"
      },
      {
        "command": "julia.stopTestController",
        "category": "Julia",
        "title": "Stop Test Controller",
        "icon": "$(debug-stop)"
      },
      {
        "command": "julia.runEditorContents",
        "category": "Julia",
        "title": "Run File in Julia",
        "icon": "$(play)"
      },
      {
        "command": "julia.debugEditorContents",
        "category": "Julia",
        "title": "Debug File in Julia",
        "icon": "$(debug-alt)"
      }
    ],
    "debuggers": [
      {
        "type": "julia",
        "label": "Julia",
        "languages": [
          "julia"
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the Julia file to debug."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory for the Julia process."
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false,
                "description": "Break at the first line of the program."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Command-line arguments passed to the Julia program."
              },
              "juliaAdditionalArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Additional Julia CLI arguments (e.g. --threads=4)."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "julia",
            "request": "launch",
            "name": "Run Julia file",
            "program": "${file}",
            "stopOnEntry": false
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "julia"
      }
    ],
    "keybindings": [
      {
        "command": "julia.executeCell",
        "key": "ctrl+shift+enter",
        "when": "editorLangId == julia && editorTextFocus"
      },
      {
        "command": "julia.executeCellAndMove",
        "key": "alt+shift+enter",
        "when": "editorLangId == julia && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Julia",
      "properties": {
        "positron.julia.executablePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the Julia executable, or a juliaup channel name (e.g. `1.10`, `lts`, `release`). When set in workspace settings (`.vscode/settings.json`), this pins the project to a specific Julia version. Leave empty to use the system default.",
          "scope": "window"
        },
        "julia.lint.missingrefs": {
          "type": "string",
          "enum": [
            "all",
            "id",
            "none"
          ],
          "default": "all",
          "description": "Controls missing-reference diagnostics from the Julia Language Server."
        },
        "positron.julia.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Julia Language Server diagnostics and completions."
        },
        "positron.julia.languageServer.environmentPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a Julia project environment for Language Server analysis."
        },
        "positron.julia.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic highlighting for Julia files."
        },
        "positron.julia.semanticHighlighting.string.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic highlighting for string tokens."
        },
        "julia.NumThreads": {
          "type": [
            "integer",
            "string",
            "null"
          ],
          "default": null,
          "scope": "machine-overridable",
          "markdownDescription": "Number of threads to use for Julia processes. Set to `auto` to let Julia decide, or `null` to use the environment default."
        },
        "julia.additionalArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional Julia command-line arguments passed when starting the kernel."
        },
        "julia.packageServer": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Julia package server URL. Sets `JULIA_PKG_SERVER` before starting Julia. Leave empty to use the default."
        },
        "julia.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "enumDescriptions": [
            "No tracing",
            "Log LSP message types",
            "Log full LSP message content"
          ],
          "scope": "window",
          "description": "Traces the communication between the extension and the Julia Language Server."
        },
        "julia.lint.run": {
          "type": "boolean",
          "default": true,
          "description": "Run the linter on active Julia files."
        },
        "julia.lint.call": {
          "type": "boolean",
          "default": true,
          "description": "Check calls against method signatures."
        },
        "julia.lint.iter": {
          "type": "boolean",
          "default": true,
          "description": "Check for non-iterable values used in iteration."
        },
        "julia.lint.nothingcomp": {
          "type": "boolean",
          "default": false,
          "description": "Check for comparisons to `nothing`."
        },
        "julia.lint.constif": {
          "type": "boolean",
          "default": true,
          "description": "Check for constant conditionals in `if` statements."
        },
        "julia.lint.lazy": {
          "type": "boolean",
          "default": true,
          "description": "Check for lazy boolean operator usage."
        },
        "julia.lint.datadecl": {
          "type": "boolean",
          "default": true,
          "description": "Check for type declarations in `struct` fields."
        },
        "julia.lint.typeparam": {
          "type": "boolean",
          "default": true,
          "description": "Check for unused type parameters."
        },
        "julia.lint.modname": {
          "type": "boolean",
          "default": true,
          "description": "Check for module name conflicts."
        },
        "julia.lint.pirates": {
          "type": "boolean",
          "default": true,
          "description": "Check for type piracy."
        },
        "julia.lint.useoffuncargs": {
          "type": "boolean",
          "default": true,
          "description": "Check that all function arguments are used."
        },
        "julia.lint.disabledDirs": {
          "type": "array",
          "default": [
            "docs",
            "test"
          ],
          "items": {
            "type": "string"
          },
          "description": "Directories to exclude from linting."
        },
        "julia.completionmode": {
          "type": "string",
          "default": "qualify",
          "enum": [
            "exportedonly",
            "import",
            "qualify"
          ],
          "enumDescriptions": [
            "Show only exported names",
            "Auto-insert `import` for unexported names",
            "Complete to fully qualified name (e.g. Base.sort)"
          ],
          "scope": "window",
          "description": "Controls how unexported symbols are handled in completions."
        },
        "julia.useRevise": {
          "type": "boolean",
          "default": true,
          "description": "Automatically load Revise.jl when a Julia session starts."
        },
        "julia.numTestProcesses": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Number of Julia processes for running tests in parallel (0 = auto, one per CPU core)."
        },
        "julia.cellDelimiters": {
          "type": "array",
          "default": [
            "^\\s?#\\s#+",
            "^##(?!#)",
            "^#(\\s?)%%",
            "^#-"
          ],
          "items": {
            "type": "string"
          },
          "description": "Regular expressions used to detect code cell boundaries in Julia files."
        },
        "julia.inlayHints.static.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable static inlay hints (type annotations, parameter names) from the language server."
        },
        "julia.inlayHints.static.variableTypes.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred type hints next to variable definitions."
        },
        "julia.inlayHints.static.parameterNames.enabled": {
          "type": "string",
          "default": "literals",
          "enum": [
            "none",
            "literals",
            "all"
          ],
          "enumDescriptions": [
            "No parameter name hints",
            "Show hints for literal arguments only",
            "Show hints for all arguments"
          ],
          "description": "Show parameter name hints for function calls."
        }
      }
    },
    "menus": {
      "file/newFile": [
        {
          "command": "julia.createNewFile",
          "group": "file",
          "when": "!virtualWorkspace"
        }
      ],
      "editor/title/run": [
        {
          "when": "resourceExtname == .jl || editorLangId == julia",
          "command": "julia.runFile",
          "group": "navigation",
          "order": 0,
          "icon": "$(play)"
        },
        {
          "when": "resourceExtname == .jl || editorLangId == julia",
          "command": "julia.runSelection",
          "group": "navigation",
          "order": 2
        }
      ],
      "editor/actions/left": [
        {
          "when": "resourceExtname == .jl || editorLangId == julia",
          "command": "julia.toggleOutline",
          "group": "navigation@45"
        },
        {
          "when": "resourceExtname == .jl || editorLangId == julia",
          "command": "julia.debugEditorContents",
          "group": "navigation@46"
        }
      ]
    },
    "configurationDefaults": {
      "[julia]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test:julia": "julia --project=./julia/Positron -e \"using Pkg; Pkg.test()\"",
    "verify": "npm run compile && npm run package"
  },
  "devDependencies": {
    "@types/node": "14.x",
    "@types/glob": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^5.12.1",
    "@typescript-eslint/parser": "^5.12.1",
    "eslint": "^8.9.0",
    "typescript": "^4.5.5",
    "@vscode/vsce": "^3.3.2"
  },
  "dependencies": {
    "which": "^3.0.0",
    "semver": "^7.6.3",
    "vscode-languageclient": "^9.0.1"
  }
}
